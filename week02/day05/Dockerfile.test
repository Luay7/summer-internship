FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY checker.py .
COPY test_server.py .
COPY test_branches.py .
COPY run_tests.sh .

RUN chmod +x run_tests.sh

ENTRYPOINT ["./run_tests.sh"]
